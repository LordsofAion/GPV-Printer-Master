{
  "name": "gpv-print-manager",
  "version": "1.0.0",
  "description": "GPV Print Manager - Gestão para Gráfica, Estamparia e Papelaria",
  "author": "GPV Studio",
  "main": "electron/main.js",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "nodemon --exec ts-node -P tsconfig.server.json backend.ts",
    "seed": "ts-node -P tsconfig.server.json seed.ts",
    "electron:dev": "electron .",
    "build": "vite build",
    "build:backend": "esbuild backend.ts --bundle --platform=node --target=node18 --outfile=dist-backend/server.js --external:electron --external:@prisma/client --external:.prisma/client",
    "dist": "npm run build && npm run build:backend && electron-builder",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "generate:exe": "electron-builder --win --x64",
    "generate:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.11",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.27.3",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.gpv.manager",
    "productName": "GPV Print Manager",
    "directories": {
      "output": "dist_exe"
    },
    "win": {
      "target": "zip"
    },
    "linux": {
      "target": "tar.gz",
      "category": "Office"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".",
        "to": "prisma",
        "filter": [
          "schema.prisma",
          "dev.db"
        ]
      },
      {
        "from": "node_modules/.prisma",
        "to": "backend/node_modules/.prisma",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@prisma",
        "to": "backend/node_modules/@prisma",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}